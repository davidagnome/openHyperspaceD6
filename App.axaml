<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TerminalHyperspace.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />

    <!-- Phase 1 chrome — panel/bar/badge/section header/chip styles. -->
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#131A20"/>
      <Setter Property="BorderBrush" Value="#233040"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.bar">
      <Setter Property="Background" Value="#0E161E"/>
      <Setter Property="BorderBrush" Value="#233040"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="TextBlock.panel-title">
      <Setter Property="FontFamily" Value="avares://TerminalHyperspace/Fonts/DINishCondensed-Bold.otf#DINish Condensed"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.badge">
      <Setter Property="Background" Value="#1A2330"/>
      <Setter Property="BorderBrush" Value="#1B252F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.badge > TextBlock">
      <Setter Property="FontFamily" Value="avares://TerminalHyperspace/Fonts/DejaVuSansMono.ttf#DejaVu Sans Mono"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Foreground" Value="#506474"/>
    </Style>

    <Style Selector="TextBlock.section-h">
      <Setter Property="FontFamily" Value="avares://TerminalHyperspace/Fonts/DINishCondensed-Bold.otf#DINish Condensed"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#506474"/>
    </Style>

    <!-- Input form (the bordered "[ > ____ Execute ↵ ]" wrapper). -->
    <Style Selector="Border.input-form">
      <Setter Property="Background" Value="#08111A"/>
      <Setter Property="BorderBrush" Value="#233040"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="Button.send">
      <Setter Property="Background" Value="#4A9416"/>
      <Setter Property="BorderBrush" Value="#4A9416"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Foreground" Value="#D8E3EC"/>
      <Setter Property="FontFamily" Value="avares://TerminalHyperspace/Fonts/DINishCondensed-Bold.otf#DINish Condensed"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style Selector="Button.send /template/ ContentPresenter">
      <Setter Property="Background" Value="#4A9416"/>
      <Setter Property="BorderBrush" Value="#4A9416"/>
    </Style>
    <Style Selector="Button.send:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#77E632"/>
      <Setter Property="BorderBrush" Value="#77E632"/>
    </Style>

    <!-- Suggestion chips that replace the Command Panel buttons. -->
    <Style Selector="Button.chip">
      <Setter Property="Background" Value="#0F161C"/>
      <Setter Property="BorderBrush" Value="#1B252F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="Foreground" Value="#8AA0B3"/>
      <Setter Property="FontFamily" Value="avares://TerminalHyperspace/Fonts/DejaVuSansMono.ttf#DejaVu Sans Mono"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style Selector="Button.chip /template/ ContentPresenter">
      <Setter Property="Background" Value="#0F161C"/>
      <Setter Property="BorderBrush" Value="#1B252F"/>
    </Style>
    <Style Selector="Button.chip:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#0F161C"/>
      <Setter Property="BorderBrush" Value="#FFCA3A"/>
    </Style>
    <Style Selector="Button.chip:pointerover">
      <Setter Property="Foreground" Value="#D8E3EC"/>
    </Style>
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <!-- Shared palette — mirrored in UI/Palette.cs for code-side use. -->
      <Color x:Key="PinkCoral">#FF595E</Color>
      <Color x:Key="OrangeTangerine">#FF924C</Color>
      <Color x:Key="GoldPollen">#FFCA3A</Color>
      <Color x:Key="LimeLemon">#C5CA30</Color>
      <Color x:Key="GreenMid">#77E632</Color>
      <Color x:Key="GreenDark">#4A9416</Color>
      <Color x:Key="CyanMid">#50D5D6</Color>
      <Color x:Key="CyanDark">#36949D</Color>
      <Color x:Key="BlueMid">#1982C4</Color>
      <Color x:Key="BlueDark">#4267AC</Color>
      <Color x:Key="PurpleDark">#565AA0</Color>
      <Color x:Key="VioletMid">#C252C5</Color>
      <Color x:Key="VioletDark">#6A4C93</Color>
      <Color x:Key="BrownBg">#22171B</Color>
      <Color x:Key="GreenBg">#272D2B</Color>
      <Color x:Key="BlueBg">#171D22</Color>

      <SolidColorBrush x:Key="PinkCoralBrush"       Color="{StaticResource PinkCoral}"/>
      <SolidColorBrush x:Key="OrangeTangerineBrush" Color="{StaticResource OrangeTangerine}"/>
      <SolidColorBrush x:Key="GoldPollenBrush"      Color="{StaticResource GoldPollen}"/>
      <SolidColorBrush x:Key="LimeLemonBrush"       Color="{StaticResource LimeLemon}"/>
      <SolidColorBrush x:Key="GreenMidBrush"        Color="{StaticResource GreenMid}"/>
      <SolidColorBrush x:Key="GreenDarkBrush"       Color="{StaticResource GreenDark}"/>
      <SolidColorBrush x:Key="CyanMidBrush"         Color="{StaticResource CyanMid}"/>
      <SolidColorBrush x:Key="CyanDarkBrush"        Color="{StaticResource CyanDark}"/>
      <SolidColorBrush x:Key="BlueMidBrush"         Color="{StaticResource BlueMid}"/>
      <SolidColorBrush x:Key="BlueDarkBrush"        Color="{StaticResource BlueDark}"/>
      <SolidColorBrush x:Key="PurpleDarkBrush"      Color="{StaticResource PurpleDark}"/>
      <SolidColorBrush x:Key="VioletMidBrush"       Color="{StaticResource VioletMid}"/>
      <SolidColorBrush x:Key="VioletDarkBrush"      Color="{StaticResource VioletDark}"/>
      <SolidColorBrush x:Key="BrownBgBrush"         Color="{StaticResource BrownBg}"/>
      <SolidColorBrush x:Key="GreenBgBrush"         Color="{StaticResource GreenBg}"/>
      <SolidColorBrush x:Key="BlueBgBrush"          Color="{StaticResource BlueBg}"/>

      <!-- Font families — mirrored in UI/Fonts.cs. Keep both in sync. -->
      <FontFamily x:Key="MonoRegular">avares://TerminalHyperspace/Fonts/DejaVuSansMono.ttf#DejaVu Sans Mono</FontFamily>
      <FontFamily x:Key="MonoBold">avares://TerminalHyperspace/Fonts/DejaVuSansMono-Bold.ttf#DejaVu Sans Mono</FontFamily>
      <FontFamily x:Key="MonoOblique">avares://TerminalHyperspace/Fonts/DejaVuSansMono-Oblique.ttf#DejaVu Sans Mono</FontFamily>
      <FontFamily x:Key="MonoBoldOblique">avares://TerminalHyperspace/Fonts/DejaVuSansMono-BoldOblique.ttf#DejaVu Sans Mono</FontFamily>
      <FontFamily x:Key="DINishRegular">avares://TerminalHyperspace/Fonts/DINish-Regular.otf#DINish</FontFamily>
      <FontFamily x:Key="DINishBold">avares://TerminalHyperspace/Fonts/DINish-Bold.otf#DINish</FontFamily>
      <FontFamily x:Key="DINishItalic">avares://TerminalHyperspace/Fonts/DINish-Italic.otf#DINish</FontFamily>
      <FontFamily x:Key="DINishBoldItalic">avares://TerminalHyperspace/Fonts/DINish-BoldItalic.otf#DINish</FontFamily>
      <FontFamily x:Key="DINishCondensedRegular">avares://TerminalHyperspace/Fonts/DINishCondensed-Regular.otf#DINish Condensed</FontFamily>
      <FontFamily x:Key="DINishCondensedBold">avares://TerminalHyperspace/Fonts/DINishCondensed-Bold.otf#DINish Condensed</FontFamily>
      <FontFamily x:Key="DINishCondensedItalic">avares://TerminalHyperspace/Fonts/DINishCondensed-Italic.otf#DINish Condensed</FontFamily>
      <FontFamily x:Key="DINishCondensedBoldItalic">avares://TerminalHyperspace/Fonts/DINishCondensed-BoldItalic.otf#DINish Condensed</FontFamily>

      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="ButtonBackground" Color="#272D2B"/>
          <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#55DD55"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
