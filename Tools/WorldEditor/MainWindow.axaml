<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TerminalHyperspace.WorldEditor.MainWindow"
        Title="d6 WorldEditor"
        Width="1600" Height="900"
        Background="#0E1418">

  <DockPanel>

    <!-- ====================================================== -->
    <!-- MainPanel sidebar (far left)                            -->
    <!-- ====================================================== -->
    <Border DockPanel.Dock="Left" Width="220" Background="#171D22"
            BorderBrush="#1F2A36" BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="14,16,14,12">
          <TextBlock Text="d6"
                     FontSize="34" Foreground="#FFCA3A" FontWeight="Bold"
                     Margin="0,0,0,-4"/>
          <TextBlock Text="WorldEditor"
                     FontSize="20" Foreground="#F7FAFB" FontWeight="Bold"/>
        </StackPanel>
        <ListBox Name="MainPanel" BorderThickness="0" Background="Transparent"
                 SelectionChanged="OnMainPanelSelected" Margin="0,4,0,0">
          <ListBoxItem Content="Location"   Tag="Location"   IsSelected="True"/>
          <ListBoxItem Content="NPC"        Tag="NPC"/>
          <ListBoxItem Content="SkillCheck" Tag="SkillCheck"/>
          <ListBoxItem Content="LocChecks"  Tag="LocationChecks"/>
          <ListBoxItem Content="Missions"   Tag="Missions"/>
          <ListBoxItem Content="Item"       Tag="Item"/>
          <ListBoxItem Content="Vehicle"    Tag="Vehicle"/>
          <ListBoxItem Content="Role"       Tag="Role"/>
          <ListBoxItem Content="Species"    Tag="Species"/>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- ====================================================== -->
    <!-- Top bar (above content area)                            -->
    <!-- ====================================================== -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Background="#1A2330">
      <TextBlock Grid.Column="0" Name="TopBarLabel" Text="LocationData.cs:" Margin="10,8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
      <TextBox  Grid.Column="1" Name="PathBox" Margin="4,4" VerticalAlignment="Center"/>
      <Button   Grid.Column="2" Content="Load"   Margin="4" Click="OnLoadClick"/>
      <Button   Grid.Column="3" Content="Save"   Margin="4" Click="OnSaveClick" Background="#2D5A2D"/>
      <TextBlock Grid.Column="4" Name="StatusText" Margin="10,8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
    </Grid>

    <!-- ====================================================== -->
    <!-- Content area — one view visible at a time              -->
    <!-- ====================================================== -->
    <Grid Name="ContentHost">

      <!-- Location view: existing 3-pane editor (active by default) -->
      <Grid Name="LocationView" ColumnDefinitions="240,*,2*">

        <!-- Room list -->
        <Border Grid.Column="0" Background="#101820" BorderBrush="#1F2A36" BorderThickness="0,0,1,0">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="4">
              <TextBox  Grid.Column="0" Name="FilterBox" Watermark="filter…" KeyUp="OnFilterChanged"/>
              <Button   Grid.Column="1" Content="+" Margin="2,0" Padding="8,2" Click="OnAddRoomClick"
                        ToolTip.Tip="Add new room"/>
              <Button   Grid.Column="2" Content="−" Margin="2,0" Padding="8,2" Click="OnDeleteRoomClick"
                        ToolTip.Tip="Delete selected room"/>
            </Grid>
            <ListBox Name="RoomList" SelectionChanged="OnRoomSelected"
                     Background="Transparent" BorderThickness="0"/>
          </DockPanel>
        </Border>

        <!-- Editor form -->
        <Border Grid.Column="1" Background="#0E1418" BorderBrush="#1F2A36" BorderThickness="0,0,1,0">
          <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="EditorPanel" Spacing="6">
              <TextBlock Name="NoSelectionText"
                         Text="Select a room from the list to edit, or click + to create a new one."
                         Foreground="#888888" FontStyle="Italic"/>
              <Grid Name="EditorGrid" IsVisible="False" ColumnDefinitions="180,*">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Id*"           VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Name="EdId"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Name*"         VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Name="EdName"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Description"   VerticalAlignment="Top" Margin="0,6,0,0"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Name="EdDescription" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Planet"        VerticalAlignment="Center"/>
                <TextBox   Grid.Row="3" Grid.Column="1" Name="EdPlanet"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Star System"   VerticalAlignment="Center"/>
                <TextBox   Grid.Row="4" Grid.Column="1" Name="EdStarSystem"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Sector"        VerticalAlignment="Center"/>
                <TextBox   Grid.Row="5" Grid.Column="1" Name="EdSector"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Territory"     VerticalAlignment="Center"/>
                <TextBox   Grid.Row="6" Grid.Column="1" Name="EdTerritory"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Climate"       VerticalAlignment="Center"/>
                <ComboBox  Grid.Row="7" Grid.Column="1" Name="EdClimate" HorizontalAlignment="Stretch"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Hyperspace [x,y]" VerticalAlignment="Center"/>
                <Grid      Grid.Row="8" Grid.Column="1" ColumnDefinitions="*,*">
                  <NumericUpDown Grid.Column="0" Name="EdHyperX"/>
                  <NumericUpDown Grid.Column="1" Name="EdHyperY"/>
                </Grid>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Flags"         VerticalAlignment="Top" Margin="0,6,0,0"/>
                <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Vertical" Spacing="2">
                  <CheckBox Name="EdIsSpace"         Content="IsSpace"/>
                  <CheckBox Name="EdIsSystemSpace"   Content="IsSystemSpace"/>
                  <CheckBox Name="EdRequiresVehicle" Content="RequiresVehicle"/>
                  <CheckBox Name="EdHasShop"         Content="HasShop"/>
                  <CheckBox Name="EdHasVehicleShop"  Content="HasVehicleShop"/>
                </StackPanel>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Encounter Chance" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="10" Grid.Column="1" Name="EdEncounterChance"
                               Minimum="0" Maximum="1" Increment="0.05" FormatString="0.00"/>

                <TextBlock Grid.Row="11" Grid.Column="0" Text="Possible Encounters" VerticalAlignment="Top" Margin="0,6,0,0"/>
                <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Vertical" Spacing="3">
                  <ItemsControl Name="EdPossibleEncounters"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <ComboBox Grid.Column="0" Name="EdNpcPicker" HorizontalAlignment="Stretch"/>
                    <Button   Grid.Column="1" Content="Add"  Margin="6,0,0,0" Click="OnAddPossibleEncounterClick"/>
                  </Grid>
                </StackPanel>

                <TextBlock Grid.Row="12" Grid.Column="0" Text="Friendly NPCs"      VerticalAlignment="Top" Margin="0,6,0,0"/>
                <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Vertical" Spacing="3">
                  <CheckBox Name="EdFriendlyNPCsPresent" Content="Has FriendlyNPCs section" Click="OnFriendlyToggle"/>
                  <ItemsControl Name="EdFriendlyNPCs"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <ComboBox Grid.Column="0" Name="EdFriendlyPicker" HorizontalAlignment="Stretch"/>
                    <Button   Grid.Column="1" Content="Add" Margin="6,0,0,0" Click="OnAddFriendlyNpcClick"/>
                  </Grid>
                </StackPanel>

                <TextBlock Grid.Row="13" Grid.Column="0" Text="Space Encounters"   VerticalAlignment="Top" Margin="0,6,0,0"/>
                <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Vertical" Spacing="3">
                  <ItemsControl Name="EdSpaceEncounters"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <ComboBox Grid.Column="0" Name="EdSpacePicker" HorizontalAlignment="Stretch"/>
                    <Button   Grid.Column="1" Content="Add" Margin="6,0,0,0" Click="OnAddSpaceEncounterClick"/>
                  </Grid>
                </StackPanel>
                <TextBlock Grid.Row="14" Grid.Column="0" Text="Space Encounter Chance" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="14" Grid.Column="1" Name="EdSpaceEncounterChance"
                               Minimum="0" Maximum="1" Increment="0.05" FormatString="0.00"/>

                <TextBlock Grid.Row="15" Grid.Column="0" Text="Exits"               VerticalAlignment="Top" Margin="0,6,0,0"/>
                <StackPanel Grid.Row="15" Grid.Column="1" Orientation="Vertical" Spacing="3">
                  <ItemsControl Name="EdExits"/>
                  <Grid ColumnDefinitions="*,2*,Auto">
                    <ComboBox Grid.Column="0" Name="EdExitDir" PlaceholderText="direction" HorizontalAlignment="Stretch"/>
                    <ComboBox Grid.Column="1" Name="EdExitDest" HorizontalAlignment="Stretch"/>
                    <Button  Grid.Column="2" Content="Add" Click="OnAddExitClick"/>
                  </Grid>
                </StackPanel>

                <TextBlock Grid.Row="16" Grid.Column="0" Text="Ambient Messages"   VerticalAlignment="Top" Margin="0,6,0,0"/>
                <StackPanel Grid.Row="16" Grid.Column="1" Orientation="Vertical" Spacing="3">
                  <StackPanel Name="EdAmbient" Spacing="3"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Name="EdAmbientText" Watermark="new ambient line"/>
                    <Button  Grid.Column="1" Content="Add" Margin="6,0,0,0" Click="OnAddAmbientClick"/>
                  </Grid>
                </StackPanel>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <!-- World map canvas -->
        <Border Grid.Column="2" Background="#0A0F14">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Background="#101820">
              <TextBlock Grid.Column="0" Text="World Visualization" Margin="10,6"
                         Foreground="#88AABB" FontWeight="Bold"/>
              <Button Grid.Column="1" Content="Refresh" Margin="4" Click="OnRefreshMapClick"/>
            </Grid>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
              <Canvas Name="WorldCanvas" Background="#06090C" Width="1600" Height="1200"/>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>

      <!-- Placeholders for other menu items: each is a single-column panel
           with a "Coming soon" message and a heads-up about the planned parser. -->
      <Border Name="NPCView"        IsVisible="False" Padding="40">
        <StackPanel Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="NPC Editor"        FontSize="22" Foreground="#F7FAFB" FontWeight="Bold"/>
          <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap"
                     Text="Will edit Content/NPCData.cs — methods like `public static Character Stormtrooper() => new() { ... }`. See the parser plan in the README block of MainWindow.axaml.cs for the implementation roadmap."/>
        </StackPanel>
      </Border>
      <Border Name="SkillCheckView" IsVisible="False" Padding="40">
        <StackPanel Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="SkillCheck Editor" FontSize="22" Foreground="#F7FAFB" FontWeight="Bold"/>
          <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap"
                     Text="Will edit Content/SkillCheckData.cs — properties returning SkillCheckEvent, plus the LocationChecks dictionary that wires checks to rooms."/>
        </StackPanel>
      </Border>
      <Border Name="LocationChecksView" IsVisible="False" Padding="40">
        <StackPanel Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="LocationChecks Editor" FontSize="22" Foreground="#F7FAFB" FontWeight="Bold"/>
          <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap"
                     Text="Edits the LocationChecks dictionary in Content/SkillCheckData.cs — binds existing SkillCheckEvent members to Location ids."/>
        </StackPanel>
      </Border>
      <Border Name="MissionsView"   IsVisible="False" Padding="40">
        <StackPanel Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="Missions Editor"   FontSize="22" Foreground="#F7FAFB" FontWeight="Bold"/>
          <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap"
                     Text="Will edit Content/MissionData.cs — methods returning Mission. Includes the AllOffers list registration."/>
        </StackPanel>
      </Border>
      <Border Name="ItemView"       IsVisible="False" Padding="40">
        <StackPanel Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="Item Editor"       FontSize="22" Foreground="#F7FAFB" FontWeight="Bold"/>
          <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap"
                     Text="Will edit Content/ItemData.cs — properties returning Item, plus the StarterWeapons / AllWeapons / AllItems list registrations."/>
        </StackPanel>
      </Border>
      <Border Name="VehicleView"    IsVisible="False" Padding="40">
        <StackPanel Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="Vehicle Editor"    FontSize="22" Foreground="#F7FAFB" FontWeight="Bold"/>
          <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap"
                     Text="Will edit Content/VehicleData.cs — properties returning Vehicle. Nested Weapons + Equipment lists need first-class editors."/>
        </StackPanel>
      </Border>
      <Border Name="RoleView"       IsVisible="False" Padding="40">
        <StackPanel Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="Role Editor"       FontSize="22" Foreground="#F7FAFB" FontWeight="Bold"/>
          <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap"
                     Text="Will edit Content/RoleData.cs — list elements inside the All property's collection initializer (different shape than NPC/Item)."/>
        </StackPanel>
      </Border>
      <Border Name="SpeciesView"    IsVisible="False" Padding="40">
        <StackPanel Spacing="10" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="Species Editor"    FontSize="22" Foreground="#F7FAFB" FontWeight="Bold"/>
          <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap"
                     Text="Will edit Content/SpeciesData.cs — same shape as RoleData (list-elements-inside-All)."/>
        </StackPanel>
      </Border>

    </Grid>
  </DockPanel>
</Window>
